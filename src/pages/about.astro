---
import Layout from '../layouts/Layout.astro';
---

<Layout title="About — Cluttered Cabinet">
  <section class="max-w-4xl mx-auto px-6 md:px-12 pt-24 pb-16">
    <div class="mb-8">
      <h1 class="font-mono text-3xl text-text-primary mb-2 font-bold tracking-tight">about</h1>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-4 gap-8">
      <!-- Image Placeholder -->
      <div class="md:col-span-1">
        <div class="aspect-square bg-surface border border-border rounded flex items-center justify-center">
          <span class="text-text-secondary text-xs font-mono">img</span>
        </div>
      </div>

      <!-- Bio Content -->
      <div class="md:col-span-3 space-y-4">
        <div class="prose prose-invert max-w-none">
          <p class="text-text-primary text-sm leading-relaxed font-mono">
            hi, i'm <span class="text-accent font-bold">darpan ganatra</span>. i'm vp of machine learning & generative ai at publicis health, where i lead a team building production agentic systems — clinical reasoning agents, multi-agent orchestrators, analytics agents — deployed across 20+ pharmaceutical brands.
          </p>

          <p class="text-text-primary text-sm leading-relaxed font-mono">
            before publicis i built ml pipelines on vertex ai at amyris (biotech), and led data science teams at nbcuniversal and wwe.
          </p>

          <p class="text-text-primary text-sm leading-relaxed font-mono">
            outside of production work i'm running two independent research threads: <span class="text-accent">LUMEN</span> (token-free agent dialogue via compressed transformer states) and representation engineering for controllable llm personas (targeting neurips).
          </p>

          <p class="text-text-primary text-sm leading-relaxed font-mono">
            this site gathers experiment logs, architecture notes, and dead-ends.
          </p>

        </div>

        <!-- Links -->
        <div class="flex gap-4 pt-4 border-t border-border">
          <a href="https://www.linkedin.com/in/darpanganatra/" target="_blank" rel="noopener noreferrer" class="text-accent hover:text-accent-bright transition-colors text-sm font-mono">
            linkedin
          </a>
          <a href="https://github.com/cluttered-cabinet" target="_blank" rel="noopener noreferrer" class="text-accent hover:text-accent-bright transition-colors text-sm font-mono">
            github
          </a>
        </div>
      </div>
    </div>
  </section>
</Layout>

<style>
  .prose p {
    @apply mb-4;
  }
</style>
