---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('posts');
const publishedPosts = allPosts.filter(post => !post.data.draft);

const tagCounts = new Map<string, number>();
publishedPosts.forEach(post => {
  post.data.tags?.forEach(tag => {
    tagCounts.set(tag, (tagCounts.get(tag) || 0) + 1);
  });
});

const sortedTags = Array.from(tagCounts.entries()).sort((a, b) => a[0].localeCompare(b[0]));
---

<Layout title="Tags — Cluttered Cabinet">
  <section class="max-w-[1080px] mx-auto px-6 md:px-10 pt-16 md:pt-24 pb-20">
    <div class="border-b border-cloud-light pb-8 mb-0">
      <p class="mono-label mb-3">Index</p>
      <h1 class="font-serif font-normal text-[40px] md:text-[56px] leading-[1.05] text-slate-dark">
        Tags
      </h1>
      <p class="mono-label mt-5">{sortedTags.length} total</p>
    </div>

    {sortedTags.length > 0 ? (
      <div>
        {sortedTags.map(([tag, count]) => (
          <a href={`/tags/${tag}`} class="row-link no-underline">
            <div class="flex items-baseline justify-between gap-6">
              <span class="font-serif text-[1.6rem] text-slate-dark">
                {tag}
              </span>
              <span class="mono-label">
                {count} {count === 1 ? 'entry' : 'entries'}
              </span>
            </div>
          </a>
        ))}
      </div>
    ) : (
      <div class="py-16">
        <p class="mono-label">No tags yet</p>
      </div>
    )}
  </section>
</Layout>
