---
import Layout from '../../layouts/Layout.astro';
import TableOfContents from '../../components/TableOfContents.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('posts');
  return posts.map(post => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const projectLabels: Record<string, string> = {
  lumen: 'LUMEN',
};

const { post } = Astro.props;
const { Content } = await post.render();

const formattedDate = post.data.date;
const showTableOfContents = post.data.toc !== false;
---

<Layout title={`${post.data.title} — Cluttered Cabinet`} description={post.data.description || post.data.summary}>
  <article class="tufte-page">
    <header class="tufte-header">
      <p class="mono-label">{formattedDate}</p>

      <h1 class="post-title">{post.data.title}</h1>

      {post.data.summary && (
        <p class="post-subtitle">{post.data.summary}</p>
      )}

      {post.data.tags && post.data.tags.length > 0 && (
        <p class="post-meta">
          <span class="post-meta-label">Tags</span>
          {post.data.tags.map((tag: string, i: number) => (
            <>
              {i > 0 && <span class="post-meta-sep">·</span>}
              <a href={`/tags/${tag}`} class="post-meta-link">{tag}</a>
            </>
          ))}
        </p>
      )}

      {post.data.projects && post.data.projects.length > 0 && (
        <p class="post-meta">
          <span class="post-meta-label">Projects</span>
          {post.data.projects.map((project: string, i: number) => (
            <>
              {i > 0 && <span class="post-meta-sep">·</span>}
              <a href={`/projects#${project}`} class="post-meta-link">{projectLabels[project] ?? project}</a>
            </>
          ))}
        </p>
      )}
    </header>

    {showTableOfContents && (
      <div class="post-toc">
        <TableOfContents />
      </div>
    )}

    <div class="prose" data-article-body>
      <Content />
    </div>

    <footer class="post-footer">
      <a href="/posts" class="post-meta-link">← Back to index</a>
    </footer>
  </article>
</Layout>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const codeBlocks = document.querySelectorAll('.prose pre');

    codeBlocks.forEach((pre) => {
      const wrapper = document.createElement('div');
      wrapper.className = 'code-block-wrapper';
      pre.parentNode?.insertBefore(wrapper, pre);
      wrapper.appendChild(pre);

      const button = document.createElement('button');
      button.className = 'code-toggle';
      button.innerHTML = 'Code ▼';
      button.setAttribute('aria-expanded', 'true');

      wrapper.insertBefore(button, pre);

      button.addEventListener('click', () => {
        const isCollapsed = pre.classList.toggle('collapsed');
        button.setAttribute('aria-expanded', (!isCollapsed).toString());
        button.innerHTML = isCollapsed ? 'Code ▶' : 'Code ▼';
      });
    });
  });
</script>

<style>
  /* Tufte page: wide canvas, content biased toward the left so the right
     margin is free for sidenotes. */
  .tufte-page {
    width: 87.5%;
    max-width: 1400px;
    margin: 0 auto;
    padding: 4rem 0 6rem;
    padding-left: 12.5%;
  }

  .tufte-header {
    margin-bottom: 2.5rem;
  }

  .post-title {
    font-family: var(--font-serif);
    font-weight: 400;
    font-size: 3.4rem;
    line-height: 1.05;
    margin: 0.6rem 0 0;
    max-width: 90%;
  }

  .post-subtitle {
    font-family: var(--font-serif);
    font-style: italic;
    font-size: 1.7rem;
    line-height: 1.4;
    color: var(--ink-soft);
    margin: 1.4rem 0 0;
    max-width: 70%;
  }

  .post-meta {
    margin: 1.4rem 0 0;
    font-family: var(--font-serif);
    font-size: 1.2rem;
    color: var(--ink-muted);
  }

  .post-meta-label {
    font-style: italic;
    margin-right: 0.6rem;
  }

  .post-meta-sep {
    margin: 0 0.45rem;
    color: var(--rule);
  }

  .post-meta-link {
    color: var(--ink-muted);
    text-decoration: none;
  }

  .post-meta-link:hover {
    color: var(--ink);
    opacity: 1;
  }

  .post-toc {
    width: 55%;
    margin: 0 0 3rem;
  }

  .post-footer {
    width: 55%;
    margin-top: 4rem;
    padding-top: 1.4rem;
    border-top: 1px solid var(--rule);
  }

  /* ---- Article body --------------------------------------------------- */
  .prose {
    color: var(--ink);
    font-family: var(--font-serif);
    font-size: 1.4rem;
    line-height: 1.7;
  }

  /* Running text and most blocks live in the 55% column; sidenotes float
     into the remaining margin. */
  .prose :global(p),
  .prose :global(ol),
  .prose :global(ul),
  .prose :global(dl),
  .prose :global(blockquote),
  .prose :global(table),
  .prose :global(h4),
  .prose :global(h5),
  .prose :global(h6) {
    width: 55%;
  }

  .prose :global(h1),
  .prose :global(h2),
  .prose :global(h3) {
    max-width: 80%;
  }

  .prose :global(h1) {
    font-weight: 400;
    font-size: 2.6rem;
    line-height: 1.1;
    margin: 3rem 0 1.4rem;
  }

  .prose :global(h2) {
    font-weight: 400;
    font-style: italic;
    font-size: 2.2rem;
    line-height: 1.1;
    margin: 2.6rem 0 1.2rem;
  }

  .prose :global(h3) {
    font-weight: 400;
    font-style: italic;
    font-size: 1.7rem;
    line-height: 1.1;
    margin: 2rem 0 1rem;
  }

  .prose :global(h4) {
    font-weight: 400;
    font-style: italic;
    font-size: 1.4rem;
    margin: 1.6rem 0 0.8rem;
  }

  .prose :global(p) {
    margin: 1.4rem 0;
  }

  .prose :global(a) {
    color: var(--ink);
    text-decoration: underline;
    text-decoration-thickness: 0.5px;
    text-underline-offset: 0.15em;
    text-decoration-color: var(--ink-muted);
  }

  .prose :global(a:hover) {
    opacity: 0.6;
  }

  .prose :global(strong) {
    font-weight: 700;
  }

  .prose :global(em) {
    font-style: italic;
  }

  .prose :global(code) {
    font-family: var(--font-mono);
    font-size: 0.92em;
  }

  .prose :global(:not(pre) > code) {
    background-color: var(--paper-shade);
    padding: 0.05em 0.3em;
    border: 1px solid var(--rule);
    border-radius: 0;
    color: var(--ink);
  }

  .prose :global(pre) {
    background-color: var(--paper-shade);
    color: var(--ink);
    border: 1px solid var(--rule);
    border-radius: 0;
    padding: 1rem 1.1rem;
    overflow-x: auto;
    margin: 0;
    font-size: 1.1rem;
    line-height: 1.5;
    width: 55%;
  }

  .prose :global(pre code) {
    background: transparent;
    padding: 0;
    border: 0;
  }

  .prose :global(ul),
  .prose :global(ol) {
    padding-left: 1.6rem;
  }

  .prose :global(li) {
    margin-bottom: 0.4rem;
  }

  .prose :global(blockquote) {
    border-left: 2px solid var(--rule);
    padding: 0.25rem 0 0.25rem 1.25rem;
    color: var(--ink-soft);
    font-style: italic;
    margin: 1.6rem 0;
  }

  .prose :global(hr) {
    border: 0;
    border-top: 1px solid var(--rule);
    margin: 2.6rem 0;
    width: 55%;
  }

  .prose :global(th),
  .prose :global(td) {
    border-bottom: 1px solid var(--rule);
    padding: 0.5rem 0.75rem;
    text-align: left;
  }

  .prose :global(th) {
    border-bottom-color: var(--ink);
    font-style: italic;
    font-weight: 400;
    color: var(--ink-soft);
  }

  /* Display math can exceed the column; let it scroll rather than overlap
     the margin notes. */
  .prose :global(.katex-display) {
    width: 55%;
    overflow-x: auto;
    overflow-y: hidden;
  }

  /* Code folding control */
  :global(.code-block-wrapper) {
    width: 55%;
    margin: 1.4rem 0;
    position: relative;
  }

  :global(.code-block-wrapper pre) {
    width: 100% !important;
  }

  :global(.code-toggle) {
    width: 100%;
    text-align: left;
    padding: 0.45rem 0.8rem;
    font-family: var(--font-serif);
    font-style: italic;
    font-size: 1.1rem;
    color: var(--ink-muted);
    background-color: var(--paper-shade);
    border: 1px solid var(--rule);
    border-bottom: none;
    cursor: pointer;
    transition: color 0.15s ease;
  }

  :global(.code-toggle:hover) {
    color: var(--ink);
  }

  :global(.code-toggle + pre) {
    margin-top: 0;
  }

  :global(pre.collapsed) {
    max-height: 0;
    overflow: hidden;
    padding-top: 0 !important;
    padding-bottom: 0 !important;
    border-width: 0 !important;
  }

  /* Sidenotes are authored at 55%-column width; on narrow screens the whole
     page relaxes to a single column. */
  @media (max-width: 760px) {
    .tufte-page {
      width: 90%;
      padding-left: 0;
    }

    .post-title { max-width: 100%; font-size: 2.6rem; }
    .post-subtitle { max-width: 100%; }
    .post-toc,
    .post-footer { width: 100%; }

    .prose :global(p),
    .prose :global(ol),
    .prose :global(ul),
    .prose :global(dl),
    .prose :global(blockquote),
    .prose :global(table),
    .prose :global(pre),
    .prose :global(hr),
    .prose :global(h1),
    .prose :global(h2),
    .prose :global(h3),
    .prose :global(h4),
    .prose :global(.katex-display),
    :global(.code-block-wrapper) {
      width: 100%;
      max-width: 100%;
    }
  }
</style>
