---
import Layout from '../../layouts/Layout.astro';
import TableOfContents from '../../components/TableOfContents.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('posts');
  return posts.map(post => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const projectLabels: Record<string, string> = {
  lumen: 'LUMEN',
};

const { post } = Astro.props;
const { Content } = await post.render();

const formattedDate = post.data.date;
const showTableOfContents = post.data.toc !== false;
const contentWrapperClass = [
  'flex flex-col gap-10',
  showTableOfContents
    ? 'lg:grid lg:grid-cols-[minmax(0,1fr)_240px] lg:gap-16'
    : 'lg:max-w-3xl lg:mx-auto',
].filter(Boolean).join(' ');
const contentColumnClass = showTableOfContents
  ? 'order-2 lg:order-1 min-w-0'
  : 'min-w-0';
const tocColumnClass = 'order-1 lg:order-2 lg:pl-4';
---

<Layout title={`${post.data.title} — Cluttered Cabinet`} description={post.data.description || post.data.summary}>
  <article class="px-6 md:px-10 pt-16 md:pt-24 pb-20">
    <div class="mx-auto max-w-[1200px]">
      <header class="mb-12 border-b border-slate-dark pb-8">
        <div class="flex items-baseline gap-4 mb-6">
          <span class="mono-label">Date</span>
          <time class="mono-label" style="color: var(--color-slate-dark)">{formattedDate}</time>
        </div>

        <h1 class="font-serif text-[44px] md:text-[64px] lg:text-[76px] leading-[1.05] tracking-tight2 text-slate-dark mb-6 max-w-4xl">
          {post.data.title}
        </h1>

        {post.data.summary && (
          <p class="font-sans text-[18px] md:text-[20px] leading-[1.45] text-slate-dark max-w-3xl">
            {post.data.summary}
          </p>
        )}

        {post.data.tags && post.data.tags.length > 0 && (
          <div class="flex flex-wrap items-baseline gap-x-4 gap-y-1 mt-8">
            <span class="mono-label">Tags</span>
            {post.data.tags.map((tag: string) => (
              <a href={`/tags/${tag}`} class="mono-label hover:text-slate-dark no-underline">
                {tag}
              </a>
            ))}
          </div>
        )}

        {post.data.projects && post.data.projects.length > 0 && (
          <div class="flex flex-wrap items-baseline gap-x-4 gap-y-1 mt-3">
            <span class="mono-label">Projects</span>
            {post.data.projects.map((project: string) => (
              <a href={`/projects#${project}`} class="mono-label hover:text-slate-dark no-underline">
                {projectLabels[project] ?? project}
              </a>
            ))}
          </div>
        )}
      </header>

      <div class={contentWrapperClass}>
        <div class={contentColumnClass}>
          <div class="prose max-w-none" data-article-body>
            <Content />
          </div>
        </div>
        {showTableOfContents && (
          <div class={tocColumnClass}>
            <TableOfContents />
          </div>
        )}
      </div>

      <div class="mt-16 pt-8 border-t border-slate-dark">
        <a href="/posts" class="mono-label hover:text-slate-dark">
          ← Back to index
        </a>
      </div>
    </div>
  </article>
</Layout>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const codeBlocks = document.querySelectorAll('.prose pre');

    codeBlocks.forEach((pre) => {
      const wrapper = document.createElement('div');
      wrapper.className = 'code-block-wrapper';
      pre.parentNode?.insertBefore(wrapper, pre);
      wrapper.appendChild(pre);

      const button = document.createElement('button');
      button.className = 'code-toggle';
      button.innerHTML = 'CODE ▼';
      button.setAttribute('aria-expanded', 'true');

      wrapper.insertBefore(button, pre);

      button.addEventListener('click', () => {
        const isCollapsed = pre.classList.toggle('collapsed');
        button.setAttribute('aria-expanded', (!isCollapsed).toString());
        button.innerHTML = isCollapsed ? 'CODE ▶' : 'CODE ▼';
      });
    });
  });
</script>

<style>
  .prose {
    color: var(--color-slate-dark);
    font-family: var(--font-sans);
    font-size: 17px;
    line-height: 1.6;
    max-width: 68ch;
  }

  .prose :global(h1) {
    font-family: var(--font-serif);
    font-weight: 600;
    font-size: 32px;
    line-height: 1.15;
    letter-spacing: -0.02em;
    color: var(--color-slate-dark);
    margin: 2.5rem 0 1rem;
  }

  .prose :global(h2) {
    font-family: var(--font-serif);
    font-weight: 600;
    font-size: 26px;
    line-height: 1.2;
    letter-spacing: -0.02em;
    color: var(--color-slate-dark);
    margin: 2.25rem 0 0.85rem;
    padding-top: 1.25rem;
    border-top: 1px solid var(--color-slate-dark);
  }

  .prose :global(h3) {
    font-family: var(--font-sans);
    font-weight: 600;
    font-size: 20px;
    line-height: 1.25;
    letter-spacing: -0.02em;
    color: var(--color-slate-dark);
    margin: 1.75rem 0 0.65rem;
  }

  .prose :global(h4) {
    font-family: var(--font-sans);
    font-weight: 600;
    font-size: 17px;
    color: var(--color-slate-dark);
    margin: 1.4rem 0 0.5rem;
  }

  .prose :global(p) {
    color: var(--color-slate-dark);
    margin: 0 0 1.1rem;
  }

  .prose :global(a) {
    color: var(--color-slate-dark);
    text-decoration: underline;
    text-underline-offset: 0.18em;
    text-decoration-thickness: 1px;
  }

  .prose :global(a:hover) {
    text-decoration-thickness: 2px;
    opacity: 1;
  }

  .prose :global(strong) {
    color: var(--color-slate-dark);
    font-weight: 700;
  }

  .prose :global(em) {
    font-style: italic;
  }

  .prose :global(code) {
    font-family: var(--font-mono);
    font-size: 0.85em;
  }

  .prose :global(:not(pre) > code) {
    background-color: var(--color-ivory-medium);
    padding: 0.1em 0.35em;
    border: 1px solid var(--color-cloud-light);
    color: var(--color-slate-dark);
  }

  .prose :global(pre) {
    background-color: var(--color-ivory-medium);
    color: var(--color-slate-dark);
    border: 1px solid var(--color-slate-dark);
    border-radius: 0;
    padding: 1.1rem 1.25rem;
    overflow-x: auto;
    margin: 0;
    font-size: 13px;
    line-height: 1.6;
  }

  .prose :global(pre code) {
    background: transparent;
    padding: 0;
    border: 0;
  }

  .prose :global(ul),
  .prose :global(ol) {
    margin: 0 0 1.1rem;
    padding-left: 1.5rem;
  }

  .prose :global(ul) {
    list-style-type: none;
  }

  .prose :global(ul > li) {
    position: relative;
  }

  .prose :global(ul > li::before) {
    content: '—';
    position: absolute;
    left: -1.5rem;
    color: var(--color-cloud-dark);
  }

  .prose :global(ol) {
    list-style-type: decimal;
  }

  .prose :global(li) {
    margin-bottom: 0.4rem;
    color: var(--color-slate-dark);
  }

  .prose :global(blockquote) {
    border-left: 2px solid var(--color-slate-dark);
    padding: 0.25rem 0 0.25rem 1.25rem;
    color: var(--color-slate-light);
    font-style: italic;
    margin: 1.5rem 0;
  }

  .prose :global(hr) {
    border: 0;
    border-top: 1px solid var(--color-slate-dark);
    margin: 2.5rem 0;
  }

  .prose :global(table) {
    width: 100%;
    border-collapse: collapse;
    margin: 1.5rem 0;
    font-size: 15px;
  }

  .prose :global(th),
  .prose :global(td) {
    border-bottom: 1px solid var(--color-cloud-light);
    padding: 0.6rem 0.75rem;
    text-align: left;
  }

  .prose :global(th) {
    border-bottom-color: var(--color-slate-dark);
    font-family: var(--font-mono);
    font-size: 12px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-cloud-dark);
    font-weight: 400;
  }

  /* Code folding */
  :global(.code-block-wrapper) {
    margin: 1.25rem 0;
    position: relative;
  }

  :global(.code-toggle) {
    width: 100%;
    text-align: left;
    padding: 0.55rem 0.85rem;
    font-family: var(--font-mono);
    font-size: 12px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-cloud-dark);
    background-color: var(--color-ivory-medium);
    border: 1px solid var(--color-slate-dark);
    border-bottom: none;
    cursor: pointer;
    transition: color 0.15s ease;
  }

  :global(.code-toggle:hover) {
    color: var(--color-slate-dark);
  }

  :global(.code-toggle + pre) {
    margin-top: 0;
  }

  :global(pre.collapsed) {
    max-height: 0;
    overflow: hidden;
    padding-top: 0 !important;
    padding-bottom: 0 !important;
    border-width: 0 !important;
  }
</style>
