---
interface Props {
  title: string;
  date: string;
  summary?: string;
  slug: string;
  tags?: string[];
  index?: number;
}

const { title, date, summary, slug, tags, index } = Astro.props;
---

<a href={`/posts/${slug}`} class="row-link group no-underline">
  <div class="grid grid-cols-[auto_1fr_auto] gap-x-6 md:gap-x-10 items-baseline">
    {index !== undefined && (
      <span class="entry-num w-10 shrink-0">
        {String(index).padStart(2, '0')}
      </span>
    )}

    <div class="min-w-0">
      <h2 class="entry-title">
        {title}
      </h2>

      {summary && (
        <p class="entry-summary line-clamp-2">
          {summary}
        </p>
      )}

      {tags && tags.length > 0 && (
        <div class="flex flex-wrap gap-x-3 gap-y-1 tag-row">
          {tags.map((tag, i) => (
            <>
              {i > 0 && <span class="entry-tag-sep" aria-hidden="true">·</span>}
              <a href={`/tags/${tag}`} class="entry-tag tag-pill no-underline">
                {tag}
              </a>
            </>
          ))}
        </div>
      )}
    </div>

    <time class="entry-date shrink-0 self-start whitespace-nowrap">{date}</time>
  </div>
</a>

<style>
  .entry-num,
  .entry-date {
    font-family: var(--font-serif);
    font-style: italic;
    font-size: 1.15rem;
    color: var(--ink-muted);
  }

  .entry-title {
    font-family: var(--font-serif);
    font-weight: 400;
    color: var(--ink);
    font-size: 1.6rem;
    line-height: 1.2;
    margin-bottom: 0.3rem;
  }

  .entry-summary {
    font-family: var(--font-serif);
    color: var(--ink-soft);
    font-size: 1.3rem;
    line-height: 1.45;
    margin-bottom: 0.5rem;
  }

  .entry-tag {
    font-family: var(--font-serif);
    font-style: italic;
    font-size: 1.1rem;
    color: var(--ink-muted);
  }

  .entry-tag:hover { color: var(--ink); opacity: 1; }

  .entry-tag-sep {
    color: var(--rule);
    font-size: 1.1rem;
  }
</style>

<script>
  document.addEventListener('click', (e) => {
    const target = e.target as HTMLElement;
    if (target.classList.contains('tag-pill')) {
      e.preventDefault();
      e.stopPropagation();
      window.location.href = (target as HTMLAnchorElement).href;
    }
  });
</script>
