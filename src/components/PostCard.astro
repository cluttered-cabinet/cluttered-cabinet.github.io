---
interface Props {
  title: string;
  date: string;
  summary?: string;
  slug: string;
  tags?: string[];
  index?: number;
}

const { title, date, summary, slug, tags, index } = Astro.props;
---

<a href={`/posts/${slug}`} class="row-link group no-underline">
  <div class="grid grid-cols-[auto_1fr_auto] gap-x-6 md:gap-x-10 items-baseline">
    {index !== undefined && (
      <span class="mono-label w-10 shrink-0">
        {String(index).padStart(2, '0')}
      </span>
    )}

    <div class="min-w-0">
      <h2 class="font-sans font-semibold text-slate-dark text-[18px] md:text-[20px] leading-[1.3] tracking-tight2 mb-2">
        {title}
      </h2>

      {summary && (
        <p class="font-sans text-slate-light text-[15px] leading-[1.45] line-clamp-2 mb-3">
          {summary}
        </p>
      )}

      {tags && tags.length > 0 && (
        <div class="flex flex-wrap gap-x-4 gap-y-1 tag-row">
          {tags.map(tag => (
            <a href={`/tags/${tag}`} class="mono-label tag-pill no-underline hover:text-slate-dark">
              {tag}
            </a>
          ))}
        </div>
      )}
    </div>

    <time class="mono-label shrink-0 self-start whitespace-nowrap">{date}</time>
  </div>
</a>

<script>
  document.addEventListener('click', (e) => {
    const target = e.target as HTMLElement;
    if (target.classList.contains('tag-pill')) {
      e.preventDefault();
      e.stopPropagation();
      window.location.href = (target as HTMLAnchorElement).href;
    }
  });
</script>
