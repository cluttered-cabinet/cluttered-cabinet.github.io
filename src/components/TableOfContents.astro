---
export interface Props {
  heading?: string;
}

const { heading = "Contents" } = Astro.props as Props;
---

<div class="toc-wrapper">
  <nav class="toc-desktop" aria-label={heading} data-toc-desktop>
    <p class="toc-title">{heading}</p>
    <div data-toc-list></div>
  </nav>

  <details class="toc-mobile" data-toc-mobile>
    <summary>
      <span>{heading}</span>
      <span aria-hidden="true" class="chevron">▾</span>
    </summary>
    <div data-toc-list-mobile></div>
  </details>
</div>

<script>
  declare global {
    interface Window {
      __blogTocObserver?: IntersectionObserver;
    }
  }

  (() => {
    type TocItem = {
      id: string;
      text: string;
      level: number;
    };

    const slugify = (input: string) =>
      String(input || "")
        .toLowerCase()
        .trim()
        .replace(/[\s]+/g, "-")
        .replace(/[^a-z0-9\-]/g, "")
        .replace(/-{2,}/g, "-");

    const buildItems = (headings: HTMLHeadingElement[]): TocItem[] => {
      const counter = new Map<string, number>();
      return headings.map((heading) => {
        const level = heading.tagName === "H2" ? 2 : heading.tagName === "H3" ? 3 : 4;
        const baseId = heading.id || slugify(heading.textContent || "section");
        const count = counter.get(baseId) ?? 0;
        const id = count ? `${baseId}-${count + 1}` : baseId;
        counter.set(baseId, count + 1);
        heading.id = id;
        return {
          id,
          text: heading.textContent?.trim() || "",
          level,
        };
      });
    };

    const renderList = (items: TocItem[], holder: HTMLElement) => {
      holder.innerHTML = "";
      const ul = document.createElement("ul");
      ul.className = "toc-list";
      items.forEach((item) => {
        const li = document.createElement("li");
        li.className = `toc-item level-${item.level}`;
        const link = document.createElement("a");
        link.href = `#${item.id}`;
        link.textContent = item.text;
        link.dataset.tocLink = item.id;
        link.className = `toc-link level-${item.level}`;
        link.setAttribute("role", "link");
        li.appendChild(link);
        ul.appendChild(li);
      });
      holder.appendChild(ul);
    };

    const setActive = (id: string | null) => {
      const links = document.querySelectorAll<HTMLElement>('[data-toc-link]');
      links.forEach((link) => {
        const isActive = link.dataset.tocLink === id;
        link.classList.toggle("active", isActive);
      });
    };

    const init = () => {
      const article = document.querySelector<HTMLElement>("[data-article-body]");
      const desktopContainer = document.querySelector<HTMLElement>("[data-toc-list]");
      const mobileContainer = document.querySelector<HTMLElement>("[data-toc-list-mobile]");
      const desktopNav = document.querySelector<HTMLElement>("[data-toc-desktop]");
      const mobileDetails = document.querySelector<HTMLDetailsElement>("[data-toc-mobile]");

      if (!article || !desktopContainer || !mobileContainer || !desktopNav || !mobileDetails) {
        return;
      }

      const headings = Array.from(article.querySelectorAll<HTMLHeadingElement>("h2, h3, h4")).filter(
        (heading) => !heading.hasAttribute("data-toc-skip"),
      );

      if (!headings.length) {
        desktopNav.classList.add("hidden");
        mobileDetails.hidden = true;
        return;
      }

      const items = buildItems(headings);
      renderList(items, desktopContainer);
      renderList(items, mobileContainer);

      window.__blogTocObserver?.disconnect();

      const observer = new IntersectionObserver(
        (entries) => {
          const visible = entries
            .filter((entry) => entry.isIntersecting)
            .sort((a, b) => b.intersectionRatio - a.intersectionRatio);
          if (visible.length) {
            setActive(visible[0].target.id);
          } else {
            const scrolled = headings
              .filter((h) => h.getBoundingClientRect().top <= 120)
              .pop();
            if (scrolled) setActive(scrolled.id);
          }
        },
        {
          rootMargin: "-40% 0px -40% 0px",
          threshold: [0, 0.25, 0.5, 0.75, 1],
        },
      );

      headings.forEach((heading) => observer.observe(heading));
      window.__blogTocObserver = observer;
    };

    if (document.readyState === "loading") {
      document.addEventListener("DOMContentLoaded", init, { once: true });
    } else {
      init();
    }

    document.addEventListener("astro:after-swap", () => setTimeout(init, 0));
  })();
</script>

<style>
  .toc-wrapper {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .toc-desktop {
    display: none;
  }

  .toc-title {
    font-family: var(--font-mono);
    text-transform: uppercase;
    letter-spacing: 0.12em;
    font-size: 12px;
    color: var(--color-cloud-dark);
    margin-bottom: 0.85rem;
    padding-bottom: 0.6rem;
    border-bottom: 1px solid var(--color-slate-dark);
  }

  .toc-list {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .toc-item {
    margin: 0;
  }

  .toc-link {
    font-family: var(--font-sans);
    font-size: 14px;
    line-height: 1.4;
    color: var(--color-slate-light);
    text-decoration: none;
    display: block;
    padding: 0.35rem 0;
    transition: color 0.15s ease;
  }

  .toc-link:hover {
    color: var(--color-slate-dark);
    opacity: 1;
  }

  .toc-link.active {
    color: var(--color-slate-dark);
    text-decoration: underline;
    text-underline-offset: 0.2em;
  }

  .toc-link.level-3 {
    padding-left: 0.85rem;
    font-size: 13px;
  }

  .toc-link.level-4 {
    padding-left: 1.7rem;
    font-size: 12px;
  }

  .toc-mobile {
    border: 1px solid var(--color-slate-dark);
    background-color: var(--color-ivory-medium);
    overflow: hidden;
  }

  .toc-mobile[hidden] {
    display: none;
  }

  .toc-mobile summary {
    list-style: none;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0.85rem 1rem;
    font-family: var(--font-mono);
    font-size: 12px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-cloud-dark);
  }

  .toc-mobile summary::-webkit-details-marker {
    display: none;
  }

  .toc-mobile .chevron {
    font-size: 0.75rem;
    opacity: 0.6;
    transition: transform 0.2s ease;
  }

  .toc-mobile[open] .chevron {
    transform: rotate(180deg);
  }

  .toc-mobile [data-toc-list-mobile] {
    padding: 0.25rem 1rem 0.85rem;
  }

  @media (min-width: 1024px) {
    .toc-desktop {
      display: block;
      position: sticky;
      top: 6.5rem;
      max-height: calc(100vh - 7rem);
      overflow-y: auto;
    }

    .toc-mobile {
      display: none;
    }
  }
</style>
