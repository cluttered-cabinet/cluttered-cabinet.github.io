---
export interface Props {
  title?: string;
  description?: string;
}

const { title = 'Glossary', description } = Astro.props as Props;
---

<section class="glossary">
  <header class="glossary-header">
    <p class="glossary-eyebrow">{title}</p>
    {description && <p class="glossary-description">{description}</p>}
  </header>
  <dl class="glossary-list">
    <slot />
  </dl>
</section>

<style>
  .glossary {
    border-top: 1px solid var(--color-slate-dark);
    border-bottom: 1px solid var(--color-slate-dark);
    padding: 1.75rem 0;
    background: transparent;
    margin: 2.5rem 0;
  }

  .glossary-header {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    margin-bottom: 1.5rem;
  }

  .glossary-eyebrow {
    font-family: var(--font-mono);
    font-size: 12px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-cloud-dark);
    margin: 0;
  }

  .glossary-description {
    margin: 0;
    font-family: var(--font-sans);
    font-size: 15px;
    color: var(--color-slate-light);
    line-height: 1.5;
  }

  .glossary-list {
    display: grid;
    grid-template-columns: minmax(120px, 0.8fr) minmax(0, 2.2fr);
    gap: 1rem 1.5rem;
    margin: 0;
  }

  .glossary-list :global(dt) {
    font-family: var(--font-mono);
    font-size: 13px;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: var(--color-cloud-dark);
    margin: 0;
  }

  .glossary-list :global(dd) {
    margin: 0;
    font-family: var(--font-sans);
    font-size: 16px;
    color: var(--color-slate-dark);
    line-height: 1.5;
  }

  .glossary-list :global(dd > p:first-child) {
    margin-top: 0;
  }

  .glossary-list :global(dd > p:last-child) {
    margin-bottom: 0;
  }

  @media (max-width: 768px) {
    .glossary-list {
      display: block;
    }

    .glossary-list :global(dt) {
      margin-bottom: 0.35rem;
    }

    .glossary-list :global(dd) {
      margin-bottom: 1.1rem;
    }

    .glossary-list :global(dd:last-child) {
      margin-bottom: 0;
    }
  }
</style>
