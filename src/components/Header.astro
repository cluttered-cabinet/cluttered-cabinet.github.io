---
const currentPath = Astro.url.pathname;

const navLinks = [
  { name: 'Home', href: '/' },
  { name: 'Projects', href: '/projects' },
  { name: 'Posts', href: '/posts' },
  { name: 'Tags', href: '/tags' },
  { name: 'About', href: '/about' },
];
---

<header
  id="header"
  class="sticky top-0 left-0 right-0 z-50 bg-ivory-light border-b border-transparent transition-colors duration-150"
>
  <div class="max-w-[1080px] mx-auto px-6 md:px-10 h-[64px] flex items-baseline justify-between gap-6">
    <a href="/" class="brand hover:opacity-100" aria-label="Cluttered Cabinet home">
      Cluttered Cabinet
    </a>

    <nav class="flex items-baseline gap-5 sm:gap-7">
      {navLinks.map(link => {
        const isActive = link.href === '/'
          ? currentPath === '/'
          : currentPath.startsWith(link.href);

        return (
          <a
            href={link.href}
            class={`nav-link ${isActive ? 'is-active' : ''}`}
          >
            {link.name}
          </a>
        );
      })}
    </nav>
  </div>
</header>

<style>
  .brand {
    font-family: var(--font-serif);
    font-size: 1.35rem;
    font-weight: 400;
    font-variant: small-caps;
    letter-spacing: 0.04em;
    color: var(--ink);
  }

  .nav-link {
    font-family: var(--font-serif);
    font-size: 1.25rem;
    font-weight: 400;
    color: var(--ink-muted);
    line-height: 1;
    text-decoration: none;
    transition: color 0.15s ease;
  }

  .nav-link:hover {
    color: var(--ink);
    opacity: 1;
  }

  .nav-link.is-active {
    color: var(--ink);
    font-style: italic;
  }

  #header.scrolled {
    border-bottom-color: var(--rule);
  }
</style>

<script>
  const header = document.getElementById('header');
  window.addEventListener('scroll', () => {
    if (window.scrollY > 8) {
      header?.classList.add('scrolled');
    } else {
      header?.classList.remove('scrolled');
    }
  });
</script>
