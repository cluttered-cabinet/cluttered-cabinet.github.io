---
const currentYear = new Date().getFullYear();
---

<footer class="border-t border-cloud-light mt-24">
  <div class="max-w-[1080px] mx-auto px-6 md:px-10 py-8 flex flex-wrap items-baseline justify-between gap-4">
    <p class="footer-note">
      © {currentYear} Cluttered Cabinet
    </p>
    <p class="footer-note">
      Set in <span class="footer-em">et-book</span>, after Edward Tufte. Built with <a href="https://astro.build" target="_blank" rel="noopener noreferrer" class="tufte-link">Astro</a>.
    </p>
  </div>
</footer>

<style>
  .footer-note {
    font-family: var(--font-serif);
    font-style: italic;
    font-size: 1.2rem;
    color: var(--ink-muted);
  }

  .footer-em {
    font-style: italic;
  }
</style>
