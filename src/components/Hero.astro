    <p class="mono-label mb-6">Cluttered Cabinet · Darpan Ganatra</p>
    <div class="grid gap-10 md:grid-cols-[1.4fr_1fr] md:items-end">
      <h1 class="font-sans font-bold text-slate-dark text-[40px] sm:text-[52px] md:text-[61px] leading-[1.05] tracking-tight2 max-w-3xl">
