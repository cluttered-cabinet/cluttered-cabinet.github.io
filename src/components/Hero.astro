---
// Tufte-style hero: a large roman headline with an italic standfirst,
// set on cream paper with a single hairline rule beneath.
---

<section class="border-b border-cloud-light">
  <div class="max-w-[1080px] mx-auto px-6 md:px-10 pt-20 pb-16 md:pt-28 md:pb-20">
    <p class="hero-kicker">Cluttered Cabinet — Darpan Ganatra</p>
    <h1 class="hero-title">
      Notes on <span class="emph">agentic systems</span>, <span class="emph">representation engineering</span>, and the residue of applied&nbsp;ML.
    </h1>
    <p class="hero-standfirst">
      A working notebook of architecture sketches, latent-space probes, and dead ends — kept in public so the failures stay legible.
    </p>
  </div>
</section>

<style>
  .hero-kicker {
    font-family: var(--font-serif);
    font-style: italic;
    font-size: 1.2rem;
    color: var(--ink-muted);
    margin-bottom: 1.5rem;
  }

  .hero-title {
    font-family: var(--font-serif);
    font-weight: 400;
    color: var(--ink);
    font-size: 3rem;
    line-height: 1.1;
    max-width: 24ch;
  }

  @media (min-width: 768px) {
    .hero-title { font-size: 4rem; }
  }

  .hero-standfirst {
    font-family: var(--font-serif);
    font-style: italic;
    color: var(--ink-soft);
    font-size: 1.6rem;
    line-height: 1.45;
    max-width: 48ch;
    margin-top: 1.75rem;
  }
</style>
