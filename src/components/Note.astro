---
export interface Props {
  title?: string;
  icon?: string;
  variant?: 'note' | 'info' | 'success' | 'warning' | 'danger';
  class?: string;
}

const { title, icon, variant = 'note', class: className = '' } = Astro.props as Props;
const label = (title && title.trim().length > 0 ? title : variant).trim();
const classes = ['callout', `callout--${variant}`, 'callout-has-header', className]
  .filter(Boolean)
  .join(' ');
---

<div class={classes} data-callout={variant} data-callout-label={label}>
  {(title || icon) && (
    <div class="callout-header">
      {icon && (
        <span class="callout-icon" aria-hidden="true">
          {icon}
        </span>
      )}
      {title && <span class="callout-title">{title}</span>}
    </div>
  )}
  <div class="callout-body">
    <slot />
  </div>
</div>

<style>
  .callout-header {
    display: flex;
    align-items: center;
    gap: 0.65rem;
    margin-bottom: 0.75rem;
    font-family: var(--font-mono, 'IBM Plex Mono', monospace);
    font-size: 0.78rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--text-secondary);
  }

  .callout-title {
    font-weight: 600;
  }

  .callout-icon {
    font-size: 1rem;
    line-height: 1;
    opacity: 0.8;
  }

  .callout-body {
    font-size: 0.9rem;
    color: var(--text-primary);
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .callout-body :global(p) {
    margin: 0;
    color: inherit;
  }

  .callout-body :global(ul) {
    margin: 0;
    padding-left: 1.1rem;
  }

  .callout-body :global(li) {
    margin-bottom: 0.4rem;
    color: inherit;
  }

  .callout-body :global(li:last-child) {
    margin-bottom: 0;
  }
</style>
