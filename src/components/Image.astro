---
export interface Props {
  src: string;
  alt: string;
  caption?: string;
  credit?: string;
  figureClass?: string;
  fullWidth?: boolean;
  loading?: 'lazy' | 'eager';
}

const {
  src,
  alt,
  caption,
  credit,
  figureClass = '',
  fullWidth = false,
  loading = 'lazy',
} = Astro.props as Props;
---

<figure class={`image-block ${fullWidth ? 'image-block--full' : ''} ${figureClass}`}>
  <img src={src} alt={alt} loading={loading} decoding="async" />
  {(caption || credit) && (
    <figcaption>
      {caption && <span class="image-caption">{caption}</span>}
      {credit && <span class="image-credit">{credit}</span>}
    </figcaption>
  )}
</figure>

<style>
  .image-block {
    margin: 2.25rem 0;
    text-align: center;
  }

  .image-block img {
    width: 100%;
    max-width: 100%;
    border: 1px solid var(--color-slate-dark);
    border-radius: 0;
    display: block;
  }

  .image-block--full img {
    width: 100%;
  }

  figcaption {
    margin-top: 0.75rem;
    font-family: var(--font-mono);
    font-size: 12px;
    line-height: 1.4;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-cloud-dark);
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem;
    justify-content: center;
  }

  .image-credit {
    opacity: 0.7;
  }
</style>
