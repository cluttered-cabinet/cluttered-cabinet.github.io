---
export interface Props {
  src: string;
  alt: string;
  caption?: string;
  credit?: string;
  figureClass?: string;
  fullWidth?: boolean;
  loading?: 'lazy' | 'eager';
}

const {
  src,
  alt,
  caption,
  credit,
  figureClass = '',
  fullWidth = false,
  loading = 'lazy',
} = Astro.props as Props;
---

<figure class={`image-block ${fullWidth ? 'image-block--full' : ''} ${figureClass}`}>
  <img src={src} alt={alt} loading={loading} decoding="async" />
  {(caption || credit) && (
    <figcaption>
      {caption && <span class="image-caption">{caption}</span>}
      {credit && <span class="image-credit">{credit}</span>}
    </figcaption>
  )}
</figure>

<style>
  /* Tufte figure: sits in the text column by default; `fullWidth` lets it
     break out across the measure. Captions are set in the book face. */
  .image-block {
    margin: 2rem 0;
    max-width: 55%;
  }

  .image-block--full {
    max-width: 90%;
  }

  .image-block img {
    width: 100%;
    max-width: 100%;
    border: 0;
    border-radius: 0;
    display: block;
  }

  figcaption {
    margin-top: 0.5rem;
    font-family: var(--font-serif);
    font-style: italic;
    font-size: 1.1rem;
    line-height: 1.4;
    letter-spacing: 0;
    text-transform: none;
    color: var(--ink-muted);
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .image-credit {
    opacity: 0.7;
  }

  @media (max-width: 760px) {
    .image-block,
    .image-block--full {
      max-width: 100%;
    }
  }
</style>
