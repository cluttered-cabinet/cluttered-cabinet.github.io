---
const focusAreas = [
  {
    label: 'Multi-agent orchestration',
    body: 'Production routing, hierarchical context, and tool integration via MCP for healthcare AI.'
  },
  {
    label: 'Token-free dialogue',
    body: 'Compressed transformer states as a substrate for inter-agent communication. (LUMEN)'
  },
  {
    label: 'Representation engineering',
    body: 'DiM steering for controllable LLM personas, validated against population survey distributions.'
  }
];
---

<section class="px-6 md:px-10 py-16 md:py-20">
  <div class="max-w-[1200px] mx-auto">
    <article class="feature-dark p-8 md:p-12 lg:p-16">
      <p class="mono-label mb-8" style="color: var(--color-cloud-medium)">Working threads</p>

      <div class="grid gap-10 lg:grid-cols-[1.3fr_1fr] lg:items-end">
        <h2 class="font-serif font-normal text-ivory-light text-[36px] sm:text-[48px] md:text-[60px] lg:text-[72px] leading-[1.05] tracking-tight2 max-w-3xl">
          Building and <span class="emph">studying</span> agentic systems — from orchestration in production to control at the representation level.
        </h2>

        <div class="flex flex-col gap-5">
          <a href="/projects" class="btn-outline btn-outline-inverse self-start">
            Project archive →
          </a>
          <a href="/posts" class="btn-outline btn-outline-inverse self-start">
            Notebook entries →
          </a>
        </div>
      </div>

      <ul class="mt-12 md:mt-16 grid gap-8 md:grid-cols-3 border-t border-cloud-medium/40 pt-10">
        {focusAreas.map((item) => (
          <li class="flex flex-col gap-2">
            <span class="mono-label" style="color: var(--color-cloud-medium)">{item.label}</span>
            <p class="font-sans text-ivory-light text-[15px] leading-[1.5]">{item.body}</p>
          </li>
        ))}
      </ul>
    </article>
  </div>
</section>
