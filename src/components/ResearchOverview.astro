---
const focusAreas = [
  {
    label: 'Multi-agent orchestration',
    body: 'Production routing, hierarchical context, and tool integration via MCP for healthcare AI.'
  },
  {
    label: 'Token-free dialogue',
    body: 'Compressed transformer states as a substrate for inter-agent communication. (LUMEN)'
  },
  {
    label: 'Representation engineering',
    body: 'DiM steering for controllable LLM personas, validated against population survey distributions.'
  }
];
---

<section class="px-6 md:px-10 py-16 md:py-20 border-b border-cloud-light">
  <div class="max-w-[1080px] mx-auto">
    <p class="ro-kicker">Working threads</p>

    <h2 class="ro-heading">
      Building and <span class="emph">studying</span> agentic systems — from orchestration in production to control at the representation level.
    </h2>

    <dl class="ro-list">
      {focusAreas.map((item) => (
        <div class="ro-item">
          <dt class="ro-term">{item.label}</dt>
          <dd class="ro-desc">{item.body}</dd>
        </div>
      ))}
    </dl>

    <p class="ro-links">
      <a href="/projects" class="btn-outline">Project archive →</a>
      <a href="/posts" class="btn-outline">Notebook entries →</a>
    </p>
  </div>
</section>

<style>
  .ro-kicker {
    font-family: var(--font-serif);
    font-style: italic;
    font-size: 1.2rem;
    color: var(--ink-muted);
    margin-bottom: 1.25rem;
  }

  .ro-heading {
    font-family: var(--font-serif);
    font-weight: 400;
    color: var(--ink);
    font-size: 2.2rem;
    line-height: 1.2;
    max-width: 34ch;
  }

  @media (min-width: 768px) {
    .ro-heading { font-size: 2.8rem; }
  }

  .ro-list {
    margin-top: 3rem;
    padding-top: 2rem;
    border-top: 1px solid var(--cloud-light, #cfcdbf);
    display: grid;
    gap: 2rem;
  }

  @media (min-width: 768px) {
    .ro-list { grid-template-columns: repeat(3, 1fr); gap: 2.5rem; }
  }

  .ro-term {
    font-family: var(--font-serif);
    font-style: italic;
    font-size: 1.35rem;
    color: var(--ink);
    margin-bottom: 0.4rem;
  }

  .ro-desc {
    font-family: var(--font-serif);
    font-size: 1.3rem;
    line-height: 1.5;
    color: var(--ink-soft);
    margin: 0;
  }

  .ro-links {
    margin-top: 3rem;
    display: flex;
    flex-wrap: wrap;
    gap: 2rem;
  }
</style>
